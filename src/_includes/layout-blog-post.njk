---
layout: layout-base.njk
---

<article class="blog-post">
  <div class="container" style="max-width:760px">

    <p style="color:var(--grey);font-size:0.9rem;margin-bottom:2rem">
      <a href="/blog/">← Zurück zur Blog-Übersicht</a>
    </p>

    {% if draft %}
      <div role="status" style="background:#FFF8E1;border-left:4px solid #F9A825;padding:1rem 1.25rem;margin-bottom:2rem;border-radius:var(--radius)">
        <strong>📝 Entwurf</strong> — dieser Beitrag ist noch nicht veröffentlicht.
        Google indexiert ihn nicht, er erscheint nicht in der Blog-Übersicht.
        Sobald <code>draft: true</code> aus dem Frontmatter entfernt wird, geht er live.
      </div>
    {% endif %}

    <header class="blog-post__header" style="margin-bottom:2.5rem">
      {% if topic %}
        <p style="color:var(--red);font-weight:900;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.05em;margin:0">
          {{ topic }}
        </p>
      {% endif %}
      <h1 style="margin:0.25rem 0 1rem">{{ title }}</h1>
      <p style="color:var(--grey);font-size:0.95rem;margin:0">
        <time datetime="{{ date | isoDate }}">{{ date | dateDe }}</time>
        {% if author %} · von {{ author }}{% endif %}
        {% if readingTime %} · {{ readingTime }} Min. Lesezeit{% endif %}
      </p>
    </header>

    {% if heroImage %}
      <figure class="hero-image" style="margin-bottom:2.5rem">
        <img src="{{ heroImage }}" alt="{{ heroImageAlt or title }}" loading="eager">
        {% if heroImageCaption %}
          <figcaption style="font-size:0.85rem;color:var(--grey);margin-top:0.5rem">
            {{ heroImageCaption }}
          </figcaption>
        {% endif %}
      </figure>
    {% endif %}

    <div class="blog-post__content">
      {{ content | safe }}
    </div>

    <hr style="margin:3rem 0 2rem;border:0;border-top:1px solid var(--light)">

    <div style="background:var(--light);padding:2rem;border-radius:var(--radius);text-align:center">
      <h2 style="margin-top:0">Fotobox für Ihr nächstes Event?</h2>
      <p style="margin-bottom:1.5rem">
        14 Jahre Erfahrung, 2.500+ Events, drei Fotobox-Linien — alles aus Saarbrücken,
        überall in D · LUX.
      </p>
      <p>
        <a class="btn btn--primary" href="/kontakt/">Unverbindlich anfragen</a>
        <a class="btn btn--ghost" href="tel:{{ site.brand.phoneTel }}"
           style="background:var(--dark);color:var(--white);border:0;margin-left:0.5rem">
          📞 {{ site.brand.phone }}
        </a>
      </p>
    </div>

    <p style="margin-top:3rem;text-align:center">
      <a href="/blog/" style="color:var(--grey)">← Alle Blog-Beiträge ansehen</a>
    </p>

  </div>
</article>
