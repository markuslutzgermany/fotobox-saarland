<div class="topbar">
  <div class="container topbar__inner">
    <span class="topbar__hotline">
      <span aria-hidden="true">📞</span>
      Gratis-Hotline: <a href="tel:{{ site.brand.phoneTel }}"><strong>{{ site.brand.phone }}</strong></a> · {{ site.brand.phoneLabel }}
    </span>
    <a href="{{ site.fotodownloadUrl }}" class="topbar__fotodownload" rel="noopener">
      <svg class="topbar__fotodownload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      Fotodownload
    </a>
  </div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="logo" aria-label="{{ site.title }} — Startseite">
      <img src="/assets/img/logo-fotobox.png" alt="Foto Lutz — fotobox.saarland" class="logo__img" width="990" height="156">
    </a>

    <nav class="site-nav" aria-label="Hauptnavigation">
      <ul>
        {% for item in site.nav %}
          <li>
            <a href="{{ item.url }}"
               {% if page.url == item.url %}aria-current="page"{% endif %}>
              {{ item.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
