<div class="topbar">
  <div class="container">
    <span class="topbar__hotline">
      <span aria-hidden="true">📞</span>
      Gratis-Hotline: <a href="tel:{{ site.brand.phoneTel }}"><strong>{{ site.brand.phone }}</strong></a> · {{ site.brand.phoneLabel }}
    </span>
  </div>
</div>

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="logo" aria-label="{{ site.title }} — Startseite">
      <span class="logo__mark">FB</span>
      <span class="logo__text">FOTOBOX</span>
      <span class="logo__domain">www.fotobox.saarland</span>
    </a>

    <nav class="site-nav" aria-label="Hauptnavigation">
      <ul>
        {% for item in site.nav %}
          <li>
            <a href="{{ item.url }}"
               {% if page.url == item.url %}aria-current="page"{% endif %}>
              {{ item.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <a href="{{ site.fotodownloadUrl }}" class="btn-fotodownload" rel="noopener">
      Hier zum Fotodownload
    </a>
  </div>
</header>
