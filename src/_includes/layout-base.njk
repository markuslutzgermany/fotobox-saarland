<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }} — {{ site.tagline }}{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">

  {% if draft %}<meta name="robots" content="noindex,nofollow">{% endif %}

  {# Canonical #}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  {# Open Graph + Twitter (sister-brand-konsistent zu fotobus)
     Per-Page-Override über Frontmatter `ogImage: /assets/img/foo.jpg` möglich,
     sonst Default-Vorschaubild aus site.json (site.ogImage).
     Wichtig: og:image MUSS absolute URL sein (mit Schema). #}
  <meta property="og:type" content="website">
  <meta property="og:locale" content="de_DE">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}{{ ogImage or site.ogImage.url }}">
  <meta property="og:image:width" content="{{ ogImageWidth or site.ogImage.width }}">
  <meta property="og:image:height" content="{{ ogImageHeight or site.ogImage.height }}">
  <meta property="og:image:alt" content="{{ ogImageAlt or site.ogImage.alt }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.title }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage or site.ogImage.url }}">

  {# Favicon — generiert mit realfavicongenerator.net (04.06.2026)
     Reihenfolge ist wichtig: SVG zuerst (moderne Browser), .ico als Fallback,
     apple-touch-icon für iOS, manifest für PWA + Android Chrome. #}
  <link rel="icon" type="image/svg+xml" href="/assets/favicon/favicon.svg">
  <link rel="icon" type="image/png" sizes="96x96" href="/assets/favicon/favicon-96x96.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png">
  <link rel="manifest" href="/assets/favicon/site.webmanifest">
  <meta name="theme-color" content="#e30613">

  {# Fonts: Lato lokal (DSGVO-konform — keine externen Calls)
     CSS lädt Lato per @font-face aus /assets/fonts/, mit System-Stack als Fallback.
     Echte Lato-WOFF2-Dateien müssen unter src/assets/fonts/ abgelegt werden (TODO Markus).
  #}

  {# Eigenes CSS #}
  <link rel="stylesheet" href="/css/main.css">

  {# RSS-Feed-Autodiscovery für Browser + Feedreader #}
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }} Blog" href="/feed.xml">

  {# Schema.org LocalBusiness — global im Footer-Include nochmal als JSON-LD #}
</head>
<body>

  {# Skip-Link für Tastatur-Nutzer — springt direkt zum Hauptinhalt
     Sichtbar nur bei :focus (CSS in main.css → .skip-link) #}
  <a class="skip-link" href="#main">Zum Inhalt springen</a>

  {% include "header.njk" %}

  <main id="main" tabindex="-1">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  {# WhatsApp-Floating-Button — Dachmarken-Konsistenz mit fotobus.saarland.
     Pre-filled Text ist B2B-spezifisch für fotobox (Firmenevent). #}
  <a href="https://wa.me/496813720122?text=Hallo%2C%20ich%20interessiere%20mich%20f%C3%BCr%20eine%20Fotobox%20f%C3%BCr%20mein%20Firmenevent.%20Datum%3A%20"
     class="whatsapp-float"
     target="_blank"
     rel="noopener noreferrer"
     aria-label="WhatsApp-Chat starten"
     title="Schnell anfragen via WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
  </a>

</body>
</html>
